{
    # Disable HTTPS auto-redirect for IP-based hosting
    auto_https off
}

(cors) {
    header {
        Access-Control-Allow-Origin "http://127.0.0.1:5173"
        Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
        Access-Control-Allow-Headers "Content-Type, Authorization, Origin, Accept"
        Access-Control-Allow-Credentials "true"
    }
}

:80 {
    # Handle standard CORS preflight requests
    @options {
        method OPTIONS
    }
    handle @options {
        import cors
        respond 204
    }

    # Universal API handling
    handle /api/* {
        import cors
        
        # Auth & Admin Services
        handle /api/auth* {
            reverse_proxy auth-service:3001
        }
        
        handle /api/devices* {
            reverse_proxy auth-service:3001
        }

        handle /api/members* {
            reverse_proxy auth-service:3001
        }

        handle /api/organizations* {
            reverse_proxy auth-service:3001
        }

        handle /api/support* {
            reverse_proxy auth-service:3001
        }

        handle /api/chat* {
            reverse_proxy auth-service:3001
        }

        handle /api/analytics* {
            reverse_proxy auth-service:3001
        }

        handle /api/admin* {
            reverse_proxy auth-service:3001
        }

        # Signaling Service (WebSocket)
        handle /api/signal* {
            reverse_proxy signaling-service:3002
        }

        # Session Service
        handle /api/session* {
            reverse_proxy session-service:3003
        }

        # Billing API
        handle /api/billing* {
            uri strip_prefix /api
            reverse_proxy billing-service:3004
        }
    }

    # Desktop App Downloads & Updates
    handle /downloads/* {
        root * /var/www
        file_server browse
    }

    # Onboarding Page (Served by Auth Service)
    handle /onboard* {
        reverse_proxy auth-service:3001
    }

    # Legacy billing service (proxied to billing-service)
    handle /billing* {
        reverse_proxy billing-service:3004
    }
}
