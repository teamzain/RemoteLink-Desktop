{
    email {$EMAIL}
}

{$DOMAIN} {
    # Auth Service
    handle /api/auth* {
        reverse_proxy auth-service:3001
    }
    
    handle /api/devices* {
        reverse_proxy auth-service:3001
    }

    # Signaling Service (WebSocket)
    handle /api/signal* {
        reverse_proxy signaling-service:3002
    }

    # Session Service
    handle /api/session* {
        reverse_proxy session-service:3003
    }

    # Billing Service
    handle /billing* {
        reverse_proxy billing-service:3004
    }

    # Everything else (if you want to host static web here too)
    # reverse_proxy web:80
}
