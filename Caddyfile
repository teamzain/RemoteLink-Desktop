{
    # Disable HTTPS auto-redirect for IP-based hosting
    auto_https off
}

:80 {
    # Global CORS handling for development
    header {
        Access-Control-Allow-Origin "http://127.0.0.1:5173"
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
        Access-Control-Allow-Headers "Content-Type, Authorization"
        Access-Control-Allow-Credentials "true"
        defer
    }

    # Handle standard CORS preflight requests
    @options {
        method OPTIONS
    }
    respond @options 204

    # Health check
    handle /health {
        reverse_proxy auth-service:3001
    }

    # Auth & Admin Services
    handle /api/auth* {
        reverse_proxy auth-service:3001
    }
    
    handle /api/devices* {
        reverse_proxy auth-service:3001
    }

    handle /api/members* {
        reverse_proxy auth-service:3001
    }

    handle /api/organizations* {
        reverse_proxy auth-service:3001
    }

    # Signaling Service (WebSocket)
    handle /api/signal* {
        reverse_proxy signaling-service:3002
    }

    # Session Service
    handle /api/session* {
        reverse_proxy session-service:3003
    }

    # Billing Service
    handle /billing* {
        reverse_proxy billing-service:3004
    }
}
