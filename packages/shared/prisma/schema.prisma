generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  password       String?
  name           String?
  role           UserRole        @default(USER)
  organizationId String?
  departmentId   String?
  allowedTags      String[]        @default([]) // Tags this user is allowed to access
  allowedDeviceIds String[]        @default([]) // Specific device IDs this user can access
  organization   Organization?   @relation(fields: [organizationId], references: [id])
  department     Department?     @relation(fields: [departmentId], references: [id])
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  devices        Device[]
  savedDevices   SavedDevice[]
  sessions       Session[]
  subscription   Subscription?
  trustedDevices   TrustedDevice[]
  twoFactorSecret  String?
  is2FAEnabled         Boolean         @default(false)
  notifySessionAlert    Boolean         @default(true)
  notifyDisconnectAlert Boolean         @default(true)
  notifySoundEffects    Boolean         @default(true)
  supportTickets       SupportTicket[]
  guideRequests        GuideRequest[]
}

model Organization {
  id               String          @id @default(uuid())
  name             String
  slug             String          @unique
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  users            User[]
  devices          Device[]
  departments      Department[]
  invitations      Invitation[]
  enrollmentTokens EnrollmentToken[]

  // Org-level settings
  defaultMemberRole UserRole        @default(USER)
  require2FA       Boolean         @default(false)
}

model PlatformSettings {
  id                    Int      @id @default(1)
  defaultRelayUrl       String   @default("relay.connect-x.io")
  maxSessionDuration    Int      @default(60)
  maintenanceMode       Boolean  @default(false)
  maintenanceMessage    String?
  forceSubAdmin2FA      Boolean  @default(false)
  globalTokenLifetime   Int      @default(24)
  minPasswordLength     Int      @default(8)
  maxPasswordLength     Int      @default(32)
  defaultOrgPlan        Plan     @default(FREE)
  restrictPlanChanges   Boolean  @default(false)
  updatedAt             DateTime @updatedAt
}

model Department {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  users          User[]
  devices        Device[]
}

model Invitation {
  id             String       @id @default(uuid())
  email          String
  token          String       @unique
  role           UserRole     @default(USER)
  organizationId String
  departmentId   String?
  allowedTags      String[]     @default([])
  allowedDeviceIds String[]     @default([])
  organization     Organization @relation(fields: [organizationId], references: [id])
  expiresAt      DateTime
  createdAt      DateTime     @default(now())

  @@index([token])
}

model EnrollmentToken {
  id             String       @id @default(uuid())
  token          String       @unique
  name           String?      // Optional name for the token e.g. "Primary Enrollment"
  organizationId String
  departmentId   String?
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())
  expiresAt      DateTime?

  @@index([token])
}

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  plan                 Plan               @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  user                 User               @relation(fields: [userId], references: [id])
}

model PlanLimit {
  plan                   Plan    @id
  maxConcurrentSessions  Int
  maxDevices             Int
  sessionDurationMinutes Int
  fileTransfer           Boolean @default(false)
  sessionRecording       Boolean @default(false)
  teamMembers            Int
}

model Device {
  id                 String          @id @default(uuid())
  accessKey          String          @unique
  accessPasswordHash String?
  name               String?
  deviceType         DeviceType      @default(WINDOWS)
  status             String          @default("OFFLINE")
  ownerId            String
  organizationId     String?
  departmentId       String?
  tags               String[]        @default([])
  lastSeenAt         DateTime        @default(now())
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  owner              User            @relation(fields: [ownerId], references: [id])
  organization       Organization?   @relation(fields: [organizationId], references: [id])
  department         Department?     @relation(fields: [departmentId], references: [id])
  savedByUsers       SavedDevice[]
  trustedByViewers   TrustedDevice[]
}

model Session {
  id        String    @id @default(uuid())
  hostId    String
  viewerId  String
  startTime DateTime  @default(now())
  endTime   DateTime?
  status    String    @default("ACTIVE")
  viewer    User      @relation(fields: [viewerId], references: [id])
}

model TrustedDevice {
  viewerUserId String
  hostDeviceId String
  trustedAt    DateTime @default(now())
  hostDevice   Device   @relation(fields: [hostDeviceId], references: [id])
  viewer       User     @relation(fields: [viewerUserId], references: [id])

  @@id([viewerUserId, hostDeviceId])
}

model SavedDevice {
  userId   String
  deviceId String
  savedAt  DateTime @default(now())
  device   Device   @relation(fields: [deviceId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@id([userId, deviceId])
}

enum UserRole {
  SUPER_ADMIN
  SUB_ADMIN
  OPERATOR
  VIEWER
  USER
}

enum Plan {
  FREE
  PRO
  BUSINESS
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  TRIALING
}

enum DeviceType {
  WINDOWS
  MACOS
  LINUX
  IOS
  ANDROID
}

model SupportTicket {
  id          String   @id @default(uuid())
  displayId   String   @unique // e.g., TIC-9821
  subject     String
  category    String
  description String
  status      String   @default("Open") // Open, In Review, Closed
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GuideRequest {
  id          String   @id @default(uuid())
  description String
  status      String   @default("Pending")
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
