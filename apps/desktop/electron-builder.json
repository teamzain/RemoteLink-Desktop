{
    "appId":  "com.connectx.desktop",
    "productName":  "Remote 365",
    "electronVersion":  "28.3.3",
    "directories":  {
                        "output":  "release34"
                    },
    "files":  [
                  "dist/**/*",
                  "dist-electron/**/*",
                  "package.json",
                  {
                      "from":  "../../node_modules/@remotelink",
                      "to":  "node_modules/@remotelink",
                      "filter":  [
                                     "**/*.node",
                                     "**/*.dll"
                                 ]
                  },
                  {
                      "from":  "../../node_modules/node-datachannel",
                      "to":  "node_modules/node-datachannel",
                      "filter":  [
                                     "package.json",
                                     "dist/**/*",
                                     "build/Release/**/*"
                                 ]
                  },
                  {
                      "from":  "../../node_modules/ws",
                      "to":  "node_modules/ws"
                  },
                  {
                      "from":  "../../node_modules/bufferutil",
                      "to":  "node_modules/bufferutil"
                  },
                  {
                      "from":  "../../node_modules/utf-8-validate",
                      "to":  "node_modules/utf-8-validate"
                  },
                  {
                      "from":  "../../node_modules/node-gyp-build",
                      "to":  "node_modules/node-gyp-build"
                  }
              ],
    "extraResources":  [
                           {
                               "from":  "../../node_modules/ffmpeg-static/ffmpeg.exe",
                               "to":  "./ffmpeg.exe"
                           }
                       ],
    "asar":  true,
    "asarUnpack":  [
                       "**/*.node",
                       "**/*.dll",
                       "**/node_modules/node-datachannel/**/*"
                   ],
    "win":  {
                "target":  [
                               {
                                   "target":  "nsis",
                                   "arch":  [
                                                "x64"
                                            ]
                               }
                           ]
            },
    "nsis":  {
                 "oneClick":  false,
                 "allowToChangeInstallationDirectory":  true
             },
    "publish":  [
                    {
                        "provider":  "generic",
                        "url":  "http://159.65.84.190/downloads/desktop/"
                    }
                ]
}
